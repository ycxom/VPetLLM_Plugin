<Window x:Class="AppLauncherPlugin.winLaunchConfirm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AppLauncher - Launch Confirmation"
        SizeToContent="Height" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background" Value="#D13438"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#D13438"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C42B2F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A52528"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="&#x26A0;" FontSize="20" Foreground="#FF8C00" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Name="txtTitle"
                       Text="AI requests to launch the following application:"
                       FontSize="16"
                       Foreground="#323130"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- App Name -->
        <Border Grid.Row="1"
                Background="#FFFFFF"
                BorderBrush="#E1DFDD"
                BorderThickness="1"
                CornerRadius="8"
                Margin="0,0,0,10"
                Padding="12,8">
            <TextBlock x:Name="txtAppName"
                       FontFamily="Consolas, Courier New, monospace"
                       FontSize="16"
                       Foreground="#0078D4"
                       TextWrapping="Wrap"/>
        </Border>

        <!-- Countdown Warning -->
        <TextBlock x:Name="txtCountdown"
                   Grid.Row="2"
                   Foreground="#D13438"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,15"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="btnLaunch"
                    Content="Launch"
                    Width="100" Height="35"
                    Margin="0,0,10,0"
                    Click="BtnLaunch_Click"
                    Style="{StaticResource BtnPrimary}"/>
            <Button x:Name="btnCancel"
                    Content="Cancel"
                    Width="100" Height="35"
                    Click="BtnCancel_Click"
                    Style="{StaticResource BtnDanger}"/>
        </StackPanel>
    </Grid>
</Window>
