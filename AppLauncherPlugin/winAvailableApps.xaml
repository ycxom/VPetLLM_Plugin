<Window x:Class="AppLauncherPlugin.winAvailableApps"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="可用应用程序列表" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EDEBE9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E1DFDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="以下是当前可用的应用程序列表："
                   Foreground="#323130" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>

        <ListBox x:Name="lstAvailableApps" Grid.Row="1"
                 Background="#FFFFFF" Foreground="#323130" BorderBrush="#E1DFDD"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

        <StackPanel Orientation="Horizontal" Grid.Row="2"
                    HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock Text="提示：使用 [:plugin(AppLauncher(应用名称))] 来启动应用"
                       VerticalAlignment="Center" Margin="0,0,20,0"
                       FontStyle="Italic" Foreground="#605E5C"/>
            <Button x:Name="btnClose" Content="关闭" Width="100" Height="35" Click="btnClose_Click"
                    Style="{StaticResource BtnSecondary}"/>
        </StackPanel>
    </Grid>
</Window>
