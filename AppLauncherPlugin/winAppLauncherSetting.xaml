<Window x:Class="AppLauncherPlugin.winAppLauncherSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="应用启动器设置" Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" Color="#000000" Opacity="0.1" BlurRadius="8" ShadowDepth="2" Direction="270"/>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#605E5C"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="RowBackground" Value="#FFFFFF"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFAFA"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E1DFDD"/>
            <Setter Property="RowHeight" Value="40"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E5F1FB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EDEBE9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E1DFDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnDanger" TargetType="Button">
            <Setter Property="Background" Value="#D13438"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#D13438"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C42B2F"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#A52528"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnAction" TargetType="Button">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EDEBE9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E1DFDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 基本设置 -->
        <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                BorderBrush="#E1DFDD" BorderThickness="1"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="基本设置" Foreground="#323130" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                <CheckBox Name="chkEnableStartMenu" Content="启用开始菜单应用扫描"/>
                <CheckBox Name="chkEnableSystemApps" Content="启用系统应用"/>
                <CheckBox Name="chkEnableSteamGames" Content="启用Steam游戏支持"/>
                <CheckBox Name="chkLogLaunches" Content="记录应用启动日志"/>
                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                    <Button Name="btnRefreshApps" Content="刷新应用列表" Width="120" Margin="0,0,10,0"
                            Click="btnRefreshApps_Click"
                            Style="{StaticResource BtnAction}"/>
                    <Button Name="btnViewSteamGames" Content="查看Steam游戏" Width="120"
                            Click="btnViewSteamGames_Click"
                            Style="{StaticResource BtnAction}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 自定义应用管理 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="自定义应用管理" Foreground="#323130" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

            <DataGrid Name="dgCustomApps" Grid.Row="1" AutoGenerateColumns="False"
                      CanUserAddRows="False" SelectionMode="Single" Margin="0,0,0,10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="应用名称" Binding="{Binding Name}" Width="150"/>
                    <DataGridTextColumn Header="应用路径" Binding="{Binding Path}" Width="300"/>
                    <DataGridTextColumn Header="启动参数" Binding="{Binding Arguments}" Width="200"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- 添加/编辑应用 -->
            <Border Grid.Row="2" Background="#FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                    BorderBrush="#E1DFDD" BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="应用名称:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox Name="txtAppName" Grid.Row="0" Grid.Column="1" Margin="5" Height="28"/>

                    <Label Content="应用路径:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox Name="txtAppPath" Grid.Row="1" Grid.Column="1" Margin="5" Height="28"/>
                    <Button Name="btnBrowse" Content="浏览..." Grid.Row="1" Grid.Column="2" Margin="5"
                            Click="btnBrowse_Click"
                            Style="{StaticResource BtnAction}"/>

                    <Label Content="启动参数:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"/>
                    <TextBox Name="txtAppArgs" Grid.Row="2" Grid.Column="1" Margin="5" Height="28"/>
                </Grid>
            </Border>

            <!-- 操作按钮 -->
            <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Center">
                <Button Name="btnAddApp" Content="添加应用" Width="80" Margin="5" Height="28"
                        Click="btnAddApp_Click"
                        Style="{StaticResource BtnPrimary}"/>
                <Button Name="btnUpdateApp" Content="更新应用" Width="80" Margin="5" Height="28"
                        Click="btnUpdateApp_Click"
                        Style="{StaticResource BtnAction}"/>
                <Button Name="btnDeleteApp" Content="删除应用" Width="80" Margin="5" Height="28"
                        Click="btnDeleteApp_Click"
                        Style="{StaticResource BtnDanger}"/>
                <Button Name="btnTestApp" Content="测试启动" Width="80" Margin="5" Height="28"
                        Click="btnTestApp_Click"
                        Style="{StaticResource BtnAction}"/>
            </StackPanel>
        </Grid>

        <!-- 底部按钮 -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Name="btnViewApps" Content="查看可用应用" Width="120" Margin="0,0,10,0" Height="35"
                    Click="btnViewApps_Click"
                    Style="{StaticResource BtnSecondary}"/>
            <Button Name="btnSave" Content="保存设置" Width="100" Height="35" Margin="0,0,10,0"
                    Click="btnSave_Click"
                    Style="{StaticResource BtnPrimary}"/>
            <Button Name="btnCancel" Content="取消" Width="100" Height="35"
                    Click="btnCancel_Click"
                    Style="{StaticResource BtnSecondary}"/>
        </StackPanel>
    </Grid>
</Window>
