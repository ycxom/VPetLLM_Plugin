<UserControl x:Class="DiaryPlugin.winDiaryViewer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/VPetLLM;component/UI/Styles/PluginPanel.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部：标题 + 搜索 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="日记本" Style="{StaticResource PluginSectionHeader}"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" Grid.Column="0" Style="{StaticResource PluginTextBox}"
                         FontSize="14" KeyDown="SearchBox_KeyDown"/>
                <Button Grid.Column="1" Content="搜索" Style="{StaticResource PluginPrimaryButton}"
                        Margin="8,0,0,0" Click="Search_Click"/>
                <Button Grid.Column="2" Content="全部" Style="{StaticResource PluginSecondaryButton}"
                        Margin="8,0,0,0" Click="ShowAll_Click"/>
            </Grid>
        </StackPanel>

        <!-- 主体：左列表 + 右内容 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PluginCard}" Padding="4" Margin="0,0,12,0">
                <ListBox x:Name="DateList" BorderThickness="0" Background="Transparent"
                         SelectionChanged="DateList_SelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="6,6">
                                <TextBlock Text="{Binding Date}" FontWeight="Bold" FontSize="14"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Text="{Binding Preview}" FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           TextTrimming="CharacterEllipsis" MaxWidth="200"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource PluginCard}" Margin="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock x:Name="ContentDate" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10"/>
                        <TextBlock x:Name="ContentBody" FontSize="14"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   TextWrapping="Wrap" LineHeight="24"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 底部：操作 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,12,0,0">
            <Button Content="立即补写今天" Style="{StaticResource PluginPrimaryButton}"
                    Margin="0,0,8,0" Click="WriteToday_Click"/>
            <Button Content="删除本篇" Style="{StaticResource PluginSecondaryButton}"
                    Margin="0,0,8,0" Click="DeleteOne_Click"/>
            <Button Content="清除全部日记" Style="{StaticResource PluginDangerButton}"
                    Margin="0,0,8,0" Click="ClearAll_Click"/>
            <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
        </StackPanel>
    </Grid>
</UserControl>
