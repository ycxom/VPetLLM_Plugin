<Window x:Class="PixivPlugin.winPixivSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pixiv 插件设置" Height="520" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EDEBE9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E1DFDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="图片反向代理设置"
                       Foreground="#323130" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

            <CheckBox x:Name="chkUseImageProxy" Grid.Row="1" Content="启用图片反向代理"
                      Foreground="#323130" Margin="0,0,0,10"
                      Checked="chkUseImageProxy_Changed" Unchecked="chkUseImageProxy_Changed"/>

            <StackPanel x:Name="pnlImageProxy" Grid.Row="2" Margin="20,0,0,15">
                <TextBlock Text="代理 URL 模板:" Foreground="#605E5C" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="txtImageProxyUrl" Height="28"
                         Background="#FFFFFF" Foreground="#323130" BorderThickness="1"
                         BorderBrush="#E1DFDD" Padding="8,6"/>
                <TextBlock Foreground="#605E5C" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap">
                    占位符: {pid}=作品ID, {index}=页码(从1开始)
                    <LineBreak/>
                    单页示例: https://pixiv.shojo.cn/{pid}
                    <LineBreak/>
                    多页示例: https://pixiv.shojo.cn/{pid}-{index}
                </TextBlock>
            </StackPanel>

            <Separator Grid.Row="3" Background="#E1DFDD" Margin="0,5,0,15"/>

            <TextBlock Grid.Row="4" Text="网络代理设置（仅用于图片下载）"
                       Foreground="#323130" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>

            <CheckBox x:Name="chkUseProxy" Grid.Row="5" Content="启用网络代理"
                      Foreground="#323130" Margin="0,0,0,10"
                      Checked="chkUseProxy_Changed" Unchecked="chkUseProxy_Changed"/>

            <StackPanel Grid.Row="6" Margin="20,0,0,10">
                <RadioButton x:Name="rbFollowVPetLLM" Content="跟随 VPetLLM 代理设置"
                             Foreground="#323130" Margin="0,0,0,8" GroupName="ProxyMode"
                             Checked="ProxyMode_Changed"/>
                <RadioButton x:Name="rbCustomProxy" Content="使用自定义代理"
                             Foreground="#323130" GroupName="ProxyMode"
                             Checked="ProxyMode_Changed"/>
            </StackPanel>

            <StackPanel x:Name="pnlCustomProxy" Grid.Row="7" Margin="40,0,0,10">
                <TextBlock Text="自定义代理地址:" Foreground="#605E5C" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="txtProxyUrl" Height="28"
                         Background="#FFFFFF" Foreground="#323130" BorderThickness="1"
                         BorderBrush="#E1DFDD" Padding="8,6"/>
                <TextBlock Text="格式: http://127.0.0.1:7890" Foreground="#605E5C" FontSize="11" Margin="0,3,0,0"/>
            </StackPanel>

            <TextBlock Grid.Row="8" Foreground="#605E5C" FontSize="11" TextWrapping="Wrap" Margin="0,10,0,0">
                提示：
                <LineBreak/>
                · 图片反向代理：通过第三方服务访问 Pixiv 图片，无需配置网络代理
                <LineBreak/>
                · 网络代理：直接访问 Pixiv 图片服务器，需要能访问 Pixiv 的代理
                <LineBreak/>
                · 两者可同时启用，优先使用图片反向代理
            </TextBlock>

            <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                <Button x:Name="btnSave" Content="保存" Width="100" Height="35"
                        Margin="0,0,10,0" Click="btnSave_Click"
                        Style="{StaticResource BtnPrimary}"/>
                <Button x:Name="btnCancel" Content="取消" Width="100" Height="35"
                        Click="btnCancel_Click"
                        Style="{StaticResource BtnSecondary}"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
