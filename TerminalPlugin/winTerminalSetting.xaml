<Window x:Class="TerminalPlugin.winTerminalSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Terminal Plugin - Settings"
        Height="400" Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" Color="#000000" Opacity="0.1" BlurRadius="8" ShadowDepth="2" Direction="270"/>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#106EBE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#F3F2F1"/>
            <Setter Property="Foreground" Value="#323130"/>
            <Setter Property="BorderBrush" Value="#E1DFDD"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#EDEBE9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E1DFDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock x:Name="txtTitle"
                   Grid.Row="0"
                   Text="Terminal Settings"
                   FontSize="20"
                   Foreground="#323130"
                   FontWeight="SemiBold"
                   Margin="0,0,0,20"/>

        <!-- Settings Content -->
        <StackPanel Grid.Row="1">
            <!-- Shell Info -->
            <Border Background="#FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                    BorderBrush="#E1DFDD" BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock x:Name="txtShellInfoTitle"
                               Text="Shell Information"
                               FontSize="14"
                               Foreground="#323130"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>
                    <TextBlock x:Name="txtCurrentShell"
                               Text="Current Shell: PowerShell"
                               Foreground="#0078D4"
                               FontSize="13"/>
                    <TextBlock x:Name="txtPwshStatus"
                               Text="PowerShell 7 (pwsh): Available"
                               Foreground="#107C10"
                               FontSize="12"
                               Margin="0,5,0,0"/>
                    <TextBlock x:Name="txtPsStatus"
                               Text="Windows PowerShell: Available"
                               Foreground="#107C10"
                               FontSize="12"
                               Margin="0,3,0,0"/>
                    <TextBlock x:Name="txtCmdStatus"
                               Text="CMD: Available"
                               Foreground="#107C10"
                               FontSize="12"
                               Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- Enable Toggle -->
            <Border Background="#FFFFFF" CornerRadius="8" Padding="15" Margin="0,0,0,15"
                    BorderBrush="#E1DFDD" BorderThickness="1"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="txtEnableTitle"
                                   Text="Enable Terminal for AI"
                                   FontSize="14"
                                   Foreground="#323130"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="txtEnableDesc"
                                   Text="Allow AI to execute terminal commands"
                                   Foreground="#605E5C"
                                   FontSize="12"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="chkEnableTerminal"
                              Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="ChkEnableTerminal_Changed"
                              Unchecked="ChkEnableTerminal_Changed"/>
                </Grid>
            </Border>

            <!-- Warning -->
            <Border x:Name="borderWarning"
                    Background="#FDE7E9"
                    BorderBrush="#D13438"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="15"
                    Visibility="Visible">
                <StackPanel>
                    <TextBlock x:Name="txtWarningTitle"
                               Text="Warning"
                               FontSize="14"
                               Foreground="#D13438"
                               FontWeight="Bold"/>
                    <TextBlock x:Name="txtWarningDesc"
                               Text="When enabled, AI can execute commands that may modify your system. Only enable if you can verify command safety."
                               Foreground="#323130"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="btnSave"
                    Content="Save"
                    Width="100" Height="35"
                    Margin="0,0,10,0"
                    Click="BtnSave_Click"
                    Style="{StaticResource BtnPrimary}"/>
            <Button x:Name="btnClose"
                    Content="Close"
                    Width="100" Height="35"
                    Click="BtnClose_Click"
                    Style="{StaticResource BtnSecondary}"/>
        </StackPanel>
    </Grid>
</Window>
