<Window x:Class="OneBotPlugin.winOneBotSetting"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OneBot Settings"
        Width="520" Height="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E2E">
    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#BAC2DE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4,8,4"/>
        </Style>
        <Style x:Key="InputStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>
        <Style x:Key="CheckBoxStyle" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#BAC2DE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Forward WebSocket (Client mode) -->
                <TextBlock Style="{StaticResource SectionHeader}" x:Name="lblForwardWS" Text="Forward WebSocket (Client → NapCat/Lagrange)"/>
                <CheckBox x:Name="chkForwardWS" Style="{StaticResource CheckBoxStyle}" Content="Enable"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" Text="WS URL:"/>
                    <TextBox Grid.Column="1" x:Name="txtForwardWSUrl" Style="{StaticResource InputStyle}"/>
                </Grid>

                <!-- Reverse WebSocket (Server mode) -->
                <TextBlock Style="{StaticResource SectionHeader}" x:Name="lblReverseWS" Text="Reverse WebSocket (Server ← AstrBot/NoneBot)"/>
                <CheckBox x:Name="chkReverseWS" Style="{StaticResource CheckBoxStyle}" Content="Enable"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Host:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtReverseWSHost" Style="{StaticResource InputStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Port:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtReverseWSPort" Style="{StaticResource InputStyle}"/>
                </Grid>

                <!-- HTTP API -->
                <TextBlock Style="{StaticResource SectionHeader}" x:Name="lblHttpApi" Text="HTTP API"/>
                <CheckBox x:Name="chkHttpApi" Style="{StaticResource CheckBoxStyle}" Content="Enable"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Style="{StaticResource LabelStyle}" Text="API URL:"/>
                    <TextBox Grid.Column="1" x:Name="txtHttpApiUrl" Style="{StaticResource InputStyle}"/>
                </Grid>

                <!-- Auth -->
                <TextBlock Style="{StaticResource SectionHeader}" x:Name="lblAuth" Text="Authentication"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Token:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtAccessToken" Style="{StaticResource InputStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" Text="Bot QQ:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtBotQQ" Style="{StaticResource InputStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource LabelStyle}" x:Name="lblMasterQQ" Text="Master QQ:"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="txtMasterQQ" Style="{StaticResource InputStyle}"/>
                </Grid>

                <!-- Filter -->
                <TextBlock Style="{StaticResource SectionHeader}" x:Name="lblFilter" Text="Message Filter"/>
                <CheckBox x:Name="chkAllowAllPrivate" Style="{StaticResource CheckBoxStyle}" Content="Allow all private messages"/>
                <CheckBox x:Name="chkAllowAllGroup" Style="{StaticResource CheckBoxStyle}" Content="Allow all group messages"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource LabelStyle}" x:Name="lblAllowedUsers" Text="Users:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtAllowedUsers" Style="{StaticResource InputStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource LabelStyle}" x:Name="lblAllowedGroups" Text="Groups:"/>
                    <TextBox Grid.Row="1" Grid.Column="1" x:Name="txtAllowedGroups" Style="{StaticResource InputStyle}"/>
                </Grid>

                <!-- Behavior -->
                <TextBlock Style="{StaticResource SectionHeader}" x:Name="lblBehavior" Text="Behavior"/>
                <CheckBox x:Name="chkAtTriggerOnly" Style="{StaticResource CheckBoxStyle}" Content="Group: respond only when @bot"/>
                <CheckBox x:Name="chkReplyWithAt" Style="{StaticResource CheckBoxStyle}" Content="Group: reply with @sender"/>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                    <Button x:Name="btnCancel" Style="{StaticResource BtnSecondary}" Content="Cancel" Click="BtnCancel_Click" Margin="0,0,8,0"/>
                    <Button x:Name="btnSave" Style="{StaticResource BtnPrimary}" Content="Save" Click="BtnSave_Click"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
